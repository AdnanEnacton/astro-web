---
import {
  getCollection,
  getEntry,
  type CollectionEntry,
  type CollectionKey,
} from "astro:content";

type PageData = {
  title: string;
  meta_title?: string;
  description?: string;
  image?: string;
  draft?: boolean;
};

export const getSinglePage = async <C extends CollectionKey>(
  collectionName: C
): Promise<CollectionEntry<C>[]> => {
  try {
    const allPages = await getCollection(
      collectionName,
      ({ data, id }: CollectionEntry<C>) =>
        !(data as PageData)?.draft && !id.startsWith("-") && !id.endsWith("-index")
    );
    return allPages;
  } catch {
    return [];
  }
};

export const getListPage = async <C extends CollectionKey>(
  collectionName: C,
  documentId: "-index" | string
): Promise<CollectionEntry<C> | null> => {
  try {
    const data = (await getEntry(
      collectionName,
      documentId
    )) as CollectionEntry<C> | null;

    return data;
  } catch {
    return null;
  }
};
---
