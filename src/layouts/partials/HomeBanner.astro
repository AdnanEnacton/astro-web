---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getRelativeLocaleUrl } from "astro:i18n";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";

const getLocaleUrl = (url: string) => {
  if (!url) return "";
  return url.startsWith("http") || url.startsWith("mailto:") || url.startsWith("tel:") || url.startsWith("#")
    ? url
    : getRelativeLocaleUrl(locale, url.startsWith("/") ? url : `/${url}`);
};

const { content, tinaFieldPath, parentData } = Astro.props;
let sectionData;
if (content) {
  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      description: content.content,
      buttons: [
        content.button_primary,
        content.button_secondary
      ].filter(Boolean),
      images: content.images || [
        { src: "/images/banner-main.png", alt: "banner-main" },
        { src: "/images/banner-1.png", alt: "banner-1" },
        { src: "/images/banner-2.png", alt: "banner-2" },
        { src: "/images/banner-3.png", alt: "banner-3" },
      ]
    }
  };
} else {
  const defaultData = await getListPage("homeBannerSection", `${locale}/home-banner`);
  if (!defaultData) return null;
  sectionData = defaultData;
}

if (!sectionData?.data?.enable) {
  return null;
}

const { title, description, buttons, images } = sectionData.data;
---

<section class="pb-0 pt-16">
  <div class="container">
    <div class="row justify-center">
      <div class="mb-8 text-center md:col-9 lg:col-11">
        {title && (
          <h1
            set:html={markdownify(title)}
            data-aos="fade-up-sm"
            class="mb-4 text-h3 lg:text-h1"
            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined}
          />
        )}
        {description && (
          <p
            set:html={markdownify(description)}
            data-aos="fade-up-sm"
            class="mb-8 text-lg/[inherit]"
            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.content`) : undefined}
          />
        )}
        {buttons && (
          <ul class="flex flex-wrap justify-center gap-4">
            {(buttons as any[]).map(({ label, link }: any, index: number) => {
              const buttonField = index === 0 ? "button_primary" : "button_secondary";
              return (
                <li data-aos="fade-up-sm" data-aos-delay={100 + index * 50}>
                  <a
                    class={`${index === 0 ? "btn-primary" : "btn-outline-primary"} btn `}
                    href={getLocaleUrl(link)}
                    title={label}
                    target={link.startsWith("http") ? "_blank" : "_self"}
                    rel="noopener"
                    data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.${buttonField}`) : undefined}>
                    {label}
                    <span class="sr-only">Details</span>
                    <span class="icon-wrapper">
                      <span class="icon">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                      <span class="icon" aria-hidden="true">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                    </span>
                  </a>
                </li>
              );
            })}
          </ul>
        )}
      </div>
      {images && (
        <>
          <div
            class="col-12 lg:pt-2 order-2"
            data-aos="fade-up-sm"
            data-aos-delay="400">
            <div class="max-h-[510px] overflow-hidden" data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.images.0`) : undefined}>
              {(images as any[])[0] && (
                <ImageMod src={(images as any[])[0].src} alt={(images as any[])[0].alt} title={(images as any[])[0].alt} />
              )}
            </div>
          </div>
          <div class="col-12 pb-4 pt-16 lg:pb-0 order-1">
            <div class="flex flex-wrap justify-center gap-4 px-4 lg:flex-nowrap lg:justify-between lg:px-0">
              {(images as any[]).slice(1, 4).map(({ src, alt }: any, index: number) => (
                <div
                  class={`${index === 0 ? "lg:mt-8 [&.aos-animate]:lg:rotate-[-9.4deg]!" : index === 1 ? "[&.aos-animate]:lg:rotate-[2.57deg]!" : "[&.aos-animate]:lg:rotate-[-8.52deg]!"}`}
                  data-aos="fade-in"
                  data-aos-duration="400"
                  data-aos-delay={150 + index * 150 + 50}
                  data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.images.${index + 1}`) : undefined}>
                  <ImageMod
                    src={src}
                    alt={alt}
                    title={alt}
                    class={`${index === 0 ? "min-[350px]:h-20 lg:h-[72px] custom-shadow" : index === 1 ? "custom-shadow-sm min-[350px]:h-20 lg:h-[98px]" : "custom-shadow min-[350px]:h-20 lg:h-[84px]"} rounded-md md:rounded-xl w-auto`}
                  />
                </div>
              ))}
            </div>
          </div>
        </>
      )}
    </div>
  </div>
</section>
