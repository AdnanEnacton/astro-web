---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getRelativeLocaleUrl } from "astro:i18n";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";

const getLocaleUrl = (url: string) => {
  if (!url) return "";
  return url.startsWith("http") || url.startsWith("mailto:") || url.startsWith("tel:") || url.startsWith("#")
    ? url
    : getRelativeLocaleUrl(locale, url.startsWith("/") ? url : `/${url}`);
};

const { content, largeHeading, tinaFieldPath, parentData } = Astro.props;

let sectionData;
if (content) {
  let list = content.list || [];
  if (content.type === "stats_grid") {
    list = content.items?.map((item: any) => ({
      title: item.role,
      description: `**${item.tagline}**<br/>${item.description}`,
    })) || [];
  } else if (content.type === "business_needs") {
    list = content.items?.map((item: any) => ({
      title: item.title,
      description: item.content,
      icon: item.icon,
    })) || [];
  } else if (content.type === "our_features") {
    list = content.items?.map((item: any) => ({
      title: item.title,
      description: item.description,
      icon: item.logo,
    })) || [];
  }

  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      subtitle: content.subtitle || "",
      description: content.description || content.content || "",
      list,
    }
  };
} else {
  const defaultData = await getListPage("featuresGridSection", `${locale}/features-grid`);
  if (!defaultData) return null;
  sectionData = defaultData;
}

if (!sectionData?.data?.enable) {
  return null;
}

let { title, subtitle, description, list } = sectionData.data;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-8" data-aos="fade-up-sm">
        {
          subtitle && (
            <p
              class="mb-2 font-medium text-tertiary"
              set:html={markdownify(subtitle)}
              data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.subtitle`) : undefined}
            />
          )
        }
        {
          title &&
            (largeHeading ? (
              <h1 class="h2 md:h1 mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />
            ) : (
              <h2 class="mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />
            ))
        }
        {
          description && (
            <p class="text-lg/[inherit]" set:html={markdownify(description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.description`) : undefined} />
          )
        }
      </div>
      <div class="col-12 pt-20">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          {
            list?.map((item: any, index: number) =>
              !((index + 1) % 3 === 0) ? (
                <div
                  class="col-span-1"
                  data-aos="fade-up-sm"
                  data-aos-delay={index * 150}
                  data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}`) : undefined}>
                  <div
                    class={`${(index + 1) % 3 === 0 ? "rounded-s-3xl" : "rounded-3xl"} flex min-h-full flex-col justify-start bg-light p-8`}>
                    {item.icon && (
                      <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary/10 text-tertiary" data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.icon`) : undefined}>
                        <DynamicIcon icon={item.icon} className="text-2xl" />
                      </div>
                    )}
                    {item.title && (
                      <h3 class="h4 mb-4" set:html={markdownify(item.title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.title`) : undefined} />
                    )}
                    {item.description && (
                      <p
                        class="mb-auto text-lg/[inherit]"
                        set:html={markdownify(item.description)}
                        data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.description`) : undefined}
                      />
                    )}



                    {item.image && (index + 1) % 3 !== 0 && (
                      <ImageMod
                        class="mt-10 rounded-3xl custom-shadow-sm"
                        src={item.image}
                        alt={`icon related to ${item.title}`}
                        title={`icon related to ${item.title}`}
                        data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.image`) : undefined}
                      />
                    )}
                  </div>
                </div>
              ) : (
                <div class="col-span-1 md:col-span-2" data-aos="fade-up-sm" data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}`) : undefined}>
                  <div class="rounded-3xl bg-light p-8">
                    <div class="row gx-0 g-5 items-center">
                      <div class="lg:col-4 lg:pe-6">
                        {item.icon && (
                          <div class="mb-4 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary/10 text-tertiary" data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.icon`) : undefined}>
                            <DynamicIcon icon={item.icon} className="text-2xl" />
                          </div>
                        )}
                        {item.title && (
                          <h3
                            class="h4 mb-4"
                            set:html={markdownify(item.title)}
                            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.title`) : undefined}
                          />
                        )}
                        {item.description && (
                          <p
                            class="text-lg/[inherit]"
                            set:html={markdownify(item.description)}
                            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.description`) : undefined}
                          />
                        )}
                        {item.button && item.button.enable && (
                          <a
                            class="btn btn-primary mt-10 w-fit"
                            href={getLocaleUrl(item.button.link)}
                            title={item.button.label}
                            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.button`) : undefined}>
                            {item.button.label}
                            <span class="sr-only">Details</span>
                            <span class="icon-wrapper">
                              <span class="icon">
                                <DynamicIcon icon={"FaArrowRight"} />
                              </span>
                              <span class="icon" aria-hidden="true">
                                <DynamicIcon icon={"FaArrowRight"} />
                              </span>
                            </span>
                          </a>
                        )}
                      </div>
                      {item.image && (
                        <div class="lg:col-8 lg:ps-6">
                          <ImageMod
                            class="rounded-3xl custom-shadow-sm"
                            src={item.image}
                            alt={`icon related to ${item.title}`}
                            title={`icon related to ${item.title}`}
                            data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.image`) : undefined}
                          />
                        </div>
                      )}
                    </div>
                  </div>
                </div>
              )
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
