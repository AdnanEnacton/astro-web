---
import AboutBanner from "@/partials/AboutBanner.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Clients from "@/partials/Clients.astro";
import Faq from "@/partials/Faq.astro";
import OurTeam from "@/partials/OurTeam.astro";
import OurValues from "@/partials/OurValues.astro";
import HowItWorks from "@/partials/HowItWorks.astro";
import FeaturesGrid from "@/partials/FeaturesGrid.astro";
import FeatureSection from "@/partials/FeatureSection.astro";
import FeaturesExplanation from "@/partials/FeaturesExplanation.astro";
import PricingSection from "@/partials/PricingSection.astro";
import Testimonial from "@/partials/Testimonial.astro";
import ContactHero from "@/partials/ContactHero.astro";
import BlogSection from "@/partials/BlogSection.astro";
import Pagination from "@/components/Pagination.astro";
import { tinaField } from "@tinacms/astro";
import { getSectionTemplate, normalizeSections } from "@/lib/tina/sections";
import { getSinglePage } from "@/lib/contentParser.astro";
import config from "@/config/config.json";

const { data, posts: postsProp, totalPages: totalPagesProp, type, locale: localeProp } = Astro.props;
const locale = localeProp || Astro.currentLocale || "de";
const sections = normalizeSections(data?.sections);

let posts = postsProp;
let totalPages = totalPagesProp;

const needsBlogData =
  sections.some((section) => {
    const template = getSectionTemplate(section);
    return template === "blog_section" || template === "pagination";
  }) && posts === undefined;

if (needsBlogData) {
  const blogPosts = (await getSinglePage("blog")).filter((post) =>
    post.id.startsWith(`${locale}/`)
  );
  posts = blogPosts;
  totalPages = Math.ceil(blogPosts.length / config.settings.pagination);
}
---

{sections.map((section: any, index: number) => {
    if (section.enable === false) return null;
    const template = getSectionTemplate(section);

    return (
      <div data-tina-field={tinaField(data, `sections.${index}`)}>
        {/* Banner Section (Handled by Layout Header, return null in body) */}
        {template === "banner" && null}

        {/* About Banner Section */}
        {template === "about_banner" && (
          <AboutBanner content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Contact Hero Section */}
        {template === "contact_hero" && (
          <ContactHero content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Clients Section */}
        {template === "clients" && (
          <Clients content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Our Values Section */}
        {template === "our_values" && (
          <OurValues content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Our Team Section */}
        {template === "our_team" && (
          <OurTeam content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* How It Works Section */}
        {template === "how_it_works" && (
          <HowItWorks content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Features Grid Section */}
        {template === "features_grid" && (
          <FeaturesGrid content={section} largeHeading={type === "features"} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Features Section */}
        {template === "features_section" && (
          <FeatureSection content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Features Explanation Section */}
        {template === "features_explanation" && (
          <FeaturesExplanation content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Pricing Section */}
        {template === "pricing" && (
          <PricingSection content={section} largeHeading={type === "pricing"} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Testimonial Section */}
        {template === "testimonial" && (
          <Testimonial content={section} visible_testimonial={3} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* Blog Section */}
        {template === "blog_section" && (
          <BlogSection
            largeHeading={section.large_heading}
            content={section}
            visiblePosts={section.visible_posts}
            cardLayout={section.card_layout}
            posts={posts}
            tinaFieldPath={`sections.${index}`}
            parentData={data}
          />
        )}

        {/* Pagination */}
        {template === "pagination" && (
          <Pagination section="blog" totalPages={totalPages} />
        )}

        {/* FAQ Section */}
        {template === "faq" && (
          <Faq content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}

        {/* CTA Section */}
        {template === "page_cta" && (
          <CallToAction content={section} tinaFieldPath={`sections.${index}`} parentData={data} />
        )}
      </div>
    );
  })}
