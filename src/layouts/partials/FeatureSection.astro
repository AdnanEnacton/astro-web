---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getRelativeLocaleUrl } from "astro:i18n";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";

const getLocaleUrl = (url: string) => {
  if (!url) return "";
  return url.startsWith("http") || url.startsWith("mailto:") || url.startsWith("tel:") || url.startsWith("#")
    ? url
    : getRelativeLocaleUrl(locale, url.startsWith("/") ? url : `/${url}`);
};

interface FeatureItem {
  title: string;
  image: string;
  description?: string;
  bulletpoints?: {
    icon?: string;
    title?: string;
    description: string;
  }[];
  button?: {
    enable: boolean;
    label: string;
    link: string;
  };
}

const { content, tinaFieldPath, parentData } = Astro.props;

let sectionData: any;
if (content) {
  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      subtitle: content.subtitle || "",
      description: content.description || "",
      list: content.list || [],
    }
  };
} else {
  const defaultData = await getListPage("featuresSection", `${locale}/features`);
  if (!defaultData) return null;
  sectionData = defaultData;
}
if (!sectionData?.data?.enable) {
  return null;
}
const { title, subtitle, description, list } = sectionData.data as {
  title: string;
  subtitle?: string;
  description?: string;
  list: FeatureItem[];
};
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-8" data-aos="fade-up-sm">
        {
          subtitle && (
            <p
              class="mb-2 font-medium text-tertiary"
              set:html={markdownify(subtitle)}
              data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.subtitle`) : undefined}
            />
          )
        }
        {title && <h2 class="mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />}
        {
          description && (
            <p class="text-lg/[inherit]" set:html={markdownify(description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.description`) : undefined} />
          )
        }
      </div>
      <div class="col-12 pt-20">
        {
          list?.map((item, index) => (
            <div
              class={`row gx-0 gy-5 mb-14 items-center last:mb-0 md:mb-28 ${index % 2 !== 0 ? "max-lg:flex-col-reverse" : ""}`}
              data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}`) : undefined}>
              <div
                class={`${index % 2 === 0 ? "" : "md:order-2"} lg:col-6`}
                data-aos="fade-up-sm"
                data-aos-delay={100}>
                <div
                  class={`overflow-hidden rounded-3xl bg-light ${index % 2 === 0 ? "pl-14 pt-14" : "px-12 py-14"}`}>
                  {item.image && (
                    <ImageMod
                      class="rounded-tl-3xl drop-shadow-lg"
                      src={item.image}
                      alt={`icon related to ${item.title}`}
                      title={`icon related to ${item.title}`}
                      data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.image`) : undefined}
                    />
                  )}
                </div>
              </div>
              <div
                class={`${index % 2 === 0 ? "lg:ps-20" : "lg:pe-20"} lg:col-6`}
                data-aos="fade-up-sm"
                data-aos-delay={300}>
                {item.title && (
                  <h3 class="h4 mb-4" set:html={markdownify(item.title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.title`) : undefined} />
                )}
                {item.description && (
                  <p
                    class="text-lg/[inherit]"
                    set:html={markdownify(item.description)}
                    data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.description`) : undefined}
                  />
                )}
 
                {item.bulletpoints && index % 2 === 0 && (
                  <div class="mt-10 flex flex-col gap-10 sm:flex-row xl:mt-20">
                    {item.bulletpoints.map((point, bulletIndex) => (
                      <div data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.bulletpoints.${bulletIndex}`) : undefined}>
                        {point.icon && (
                          <div class="mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary">
                            <ImageMod
                              class="h-6 w-6 object-cover"
                              src={point.icon}
                              alt={`icon related to ${point.title || "bulletpoint"}`}
                              title={`icon related to ${point.title || "bulletpoint"}`}
                            />
                          </div>
                        )}
                        {point.title && (
                          <h3
                            class="h6 mb-2 pt-3"
                            set:html={markdownify(point.title)}
                          />
                        )}
                        {point.description && (
                          <p set:html={markdownify(point.description)} />
                        )}
                      </div>
                    ))}
                  </div>
                )}
                {item.bulletpoints && index % 2 !== 0 && (
                  <ul class="list list-dark mt-10 flex flex-col gap-4">
                    {item.bulletpoints.map((point, bulletIndex) => (
                      <li data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.bulletpoints.${bulletIndex}`) : undefined}>
                        {point.title && (
                          <h3
                            class="h6 mb-2"
                            set:html={markdownify(point.title)}
                          />
                        )}
                        {point.description && (
                          <p
                            class="text-lg/[inherit]"
                            set:html={markdownify(point.description)}
                          />
                        )}
                      </li>
                    ))}
                  </ul>
                )}
 
                {item.button && item.button.enable && (
                  <a class="btn btn-primary mt-12" href={getLocaleUrl(item.button.link)} title={item.button.label} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.button`) : undefined}>
                    {item.button.label}
                    <span class="icon-wrapper">
                      <span class="icon">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                      <span class="icon" aria-hidden="true">
                        <DynamicIcon icon={"FaArrowRight"} />
                      </span>
                    </span>
                  </a>
                )}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
