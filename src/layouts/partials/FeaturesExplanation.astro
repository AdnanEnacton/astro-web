---
import { Image } from "astro:assets";
import ImageMod from "@/components/ImageMod.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";

const { hideHeadingBar, content, tinaFieldPath, parentData } = Astro.props;

let sectionData;
if (content) {
  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      subtitle: content.subtitle || "",
      description: content.description || "",
      image: content.image || "/images/features/features-explanation.png",
      list: content.list || [],
    }
  };
} else {
  const defaultData = await getListPage("featuresExplanationSection", `${locale}/features-explanation`);
  if (!defaultData) return null;
  sectionData = defaultData;
}

if (!sectionData?.data?.enable) {
  return null;
}
const { title, image, subtitle, description, list } = sectionData.data;
---

<section class="section">
  <div class="container">
    <div class="row">
      {
        !hideHeadingBar && (
          <div
            class="mx-auto text-center lg:col-10 xl:col-7"
            data-aos="fade-up-sm">
            {subtitle && (
              <p
                class="mb-2 font-medium text-tertiary"
                set:html={markdownify(subtitle)}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.subtitle`) : undefined}
              />
            )}
            {title && <h2 class="mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />}
            {description && (
              <p
                class="text-lg/[inherit]"
                set:html={markdownify(description)}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.description`) : undefined}
              />
            )}
          </div>
        )
      }
      <div class="col-12 pt-20">
        <div
          class="relative flex justify-center gap-3 max-xl:flex-wrap xl:mb-12 xl:mt-16 xl:flex-col xl:items-center xl:gap-y-8">
          {/* Features List */}
          {
            list?.map((item: any, mindex: number) => (
              <div
                class={`order-2 flex gap-x-3 xl:order-0 max-xl:justify-center xl:items-center ${mindex < 1 ? "flex-col max-xl:gap-y-3 md:w-[60%] xl:w-auto xl:flex-row" : "flex-col gap-y-3 sm:flex-row"}`}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${mindex}`) : undefined}>
                {/* Main Features List */}
                {item.row.map((item: any, index: number) => (
                  <div
                    class={`${(index + 1) % 2 === 0 ? "xl:order-3" : "xl:order-1"} xl:max-w-[370px]`}
                    data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${mindex}.row.${index}`) : undefined}>
                    <div
                      class="mb-12 min-h-full rounded-xl bg-light px-6 py-12 text-center last:mb-0 md:rounded-3xl"
                      data-aos="fade-up-sm"
                      data-aos-delay={index * 100}>
                      {item.title && (
                        <h3
                          class="h6 mb-2"
                          set:html={markdownify(item.title)}
                          data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${mindex}.row.${index}.title`) : undefined}
                        />
                      )}
                      {item.description && (
                        <p set:html={markdownify(item.description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${mindex}.row.${index}.description`) : undefined} />
                      )}
                    </div>
                  </div>
                ))}

                {/* Separator */}
                <div class="xl:order-2 max-xl:hidden">
                  <ImageMod
                    class="w-full"
                    src={"/images/features/line.png"}
                    alt="line svg"
                    title="line svg"
                  />
                </div>
              </div>
            ))
          }

          {/* Product Image (In Mobile Frame) */}
          {
            image && (
              <div class="order-1 w-[40%] xl:order-0 sm:w-[30%]">
                <Image
                  class="mx-auto xl:absolute xl:left-1/2 xl:top-1/2 xl:w-[35%] xl:-translate-x-1/2 xl:-translate-y-1/2"
                  src={image}
                  alt={title}
                  title={title}
                  width={907}
                  height={1856}
                  data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.image`) : undefined}
                />
              </div>
            )
          }
        </div>
      </div>
    </div>
  </div>
</section>
