---
import ImageMod from "@/components/ImageMod.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";
const { content, tinaFieldPath, parentData } = Astro.props;

const sectionData = content
  ? { data: content }
  : await getListPage("ourValuesSection", `${locale}/our-values`);
if (!sectionData?.data?.enable) {
  return null;
}
const { title, subtitle, description, list, stats } = sectionData.data;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-10" data-aos="fade-up-sm">
        {
          subtitle && (
            <p
              class="mb-2 text-tertiary font-medium"
              set:html={markdownify(subtitle)}
              data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.subtitle`) : undefined}
            />
          )
        }
        {title && <h2 class="mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />}
        {
          description && (
            <p class="text-lg/[inherit]" set:html={markdownify(description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.description`) : undefined} />
          )
        }
      </div>
      <div class="col-12 pt-20">
        <div class="row g-4 justify-center">
          {
            list?.map((item: any, index: number) => (
              <div
                class="md:col-6 lg:col-4"
                data-aos="fade-up-sm"
                data-aos-delay={200 + index * 50}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}`) : undefined}>
                <div class="min-h-full rounded-xl bg-light px-6 py-12 text-center md:rounded-3xl">
                  {item.icon && (
                    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary" data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.icon`) : undefined}>
                      <ImageMod
                        class="h-6 w-6 object-cover"
                        src={item.icon}
                        alt={`icon related to ${item.title}`}
                        title={`icon related to ${item.title}`}
                      />
                    </div>
                  )}
                  {item.title && (
                    <h3 class="h5 mb-2" set:html={markdownify(item.title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.title`) : undefined} />
                  )}
                  {item.description && (
                    <p set:html={markdownify(item.description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.description`) : undefined} />
                  )}
                </div>
              </div>
            ))
          }
        </div>
        <div class="row g-4 justify-center pt-16">
          {
            stats?.map((item: any, index: number) => (
              <div
                class="md:col-4 lg:col-4"
                data-aos="fade-up-sm"
                data-aos-delay={(stats.length - index) * 100}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.stats.${index}`) : undefined}>
                <div class="text-center">
                  {item.label && (
                    <p
                      class="mb-3 lg:text-lg/[inherit]"
                      set:html={markdownify(item.label)}
                      data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.stats.${index}.label`) : undefined}
                    />
                  )}
                  {item.value && (
                    <h3
                      class="h2 lg:h1 mb-2"
                      set:html={markdownify(item.value)}
                      data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.stats.${index}.value`) : undefined}
                    />
                  )}
                </div>
              </div>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</section>
