---
import ImageMod from "@/components/ImageMod.astro";
import DynamicIcon from "@/helpers/DynamicIcon.astro";
import { getListPage } from "@/lib/contentParser.astro";
import { markdownify } from "@/lib/utils/textConverter";
import { getRelativeLocaleUrl } from "astro:i18n";
import { tinaField } from "@tinacms/astro";

const locale = Astro.currentLocale || "de";

const getLocaleUrl = (url: string) => {
  if (!url) return "";
  return url.startsWith("http") || url.startsWith("mailto:") || url.startsWith("tel:") || url.startsWith("#")
    ? url
    : getRelativeLocaleUrl(locale, url.startsWith("/") ? url : `/${url}`);
};
const { content, tinaFieldPath, parentData } = Astro.props;
let sectionData;
if (content) {
  sectionData = {
    data: {
      enable: content.enable !== false,
      title: content.title,
      subtitle: content.subtitle || "",
      description: content.description || content.content || "",
      list: content.list || content.items?.map((item: any, index: number) => ({
        icon: item.icon || item.logo || null,
        title: item.title,
        description: item.description || item.content,
        index,
      })) || [],
      button: content.button || null
    }
  };
} else {
  const defaultData = await getListPage("howItWorksSection", `${locale}/how-it-works`);
  if (!defaultData) return null;
  sectionData = defaultData;
}

if (!sectionData?.data?.enable) {
  return null;
}

const { title, subtitle, description, list, button } = sectionData.data as any;
---

<section class="section">
  <div class="container">
    <div class="row">
      <div class="mx-auto text-center lg:col-10" data-aos="fade-up-sm">
        {
          subtitle && (
            <p
              class="mb-2 text-tertiary font-medium"
              set:html={markdownify(subtitle)}
              data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.subtitle`) : undefined}
            />
          )
        }
        {title && <h2 class="mb-6" set:html={markdownify(title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.title`) : undefined} />}
        {
          description && (
            <p class="text-lg/[inherit]" set:html={markdownify(description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.description`) : undefined} />
          )
        }
      </div>
      <div class="col-12 pt-20">
        <div class="row g-4 justify-center">
          {
            list?.map((item: any, index: number) => (
              <div
                class="md:col-6 lg:col-4"
                data-aos="fade-up-sm"
                data-aos-delay={index * 100}
                data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}`) : undefined}>
                <div class="min-h-full rounded-xl bg-light px-6 py-12 text-center md:rounded-3xl">
                  {(item.icon || item.index !== undefined) && (
                    <div class="mx-auto mb-3 flex h-12 w-12 items-center justify-center rounded-full bg-tertiary text-text-light font-bold">
                      {item.icon && item.icon.includes(":") ? (
                        <DynamicIcon icon={item.icon} className="text-2xl text-white" />
                      ) : item.icon ? (
                        <ImageMod
                          class="h-6 w-6 object-cover"
                          src={item.icon}
                          alt={`icon related to ${item.title}`}
                          title={`icon related to ${item.title}`}
                          data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.icon`) : undefined}
                        />
                      ) : (
                        <span>{item.index + 1}</span>
                      )}
                    </div>
                  )}
                  {item.title && (
                    <h3 class="h5 mb-2" set:html={markdownify(item.title)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.title`) : undefined} />
                  )}
                  {item.description && (
                    <p set:html={markdownify(item.description)} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.list.${index}.description`) : undefined} />
                  )}
                </div>
              </div>
            ))
          }
        </div>
        {
          button?.enable && (
            <div class="text-center mt-12" data-aos="fade-up-sm">
              <a class="btn btn-primary" href={getLocaleUrl(button.link)} title={button.label} data-tina-field={parentData && tinaFieldPath ? tinaField(parentData, `${tinaFieldPath}.button`) : undefined}>
                {button.label}
                <span class="icon-wrapper">
                  <span class="icon">
                    <DynamicIcon icon={"FaArrowRight"} />
                  </span>
                  <span class="icon" aria-hidden="true">
                    <DynamicIcon icon={"FaArrowRight"} />
                  </span>
                </span>
              </a>
            </div>
          )
        }
      </div>
    </div>
  </div>
</section>
