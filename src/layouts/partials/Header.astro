---
import ImageMod from "@/components/ImageMod.astro";
import Logo from "@/components/Logo.astro";
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import HomeBanner from "./HomeBanner.astro";
import { getRelativeLocaleUrl } from "astro:i18n";
import LanguageFlag from "@/components/LanguageFlag.astro";
import { useTranslations } from "@/i18n/ui";

export interface ChildNavigationLink {
  name: string;
  url: string;
}

export interface NavigationLink {
  name: string;
  url: string;
  hasChildren?: boolean;
  children?: ChildNavigationLink[];
}

const { banner, bannerData, errorPage, bannerTinaPath, parentData } = Astro.props;

const currentLocale = Astro.currentLocale || "de";
const t = useTranslations(currentLocale);
const menuData = (menu as any)[currentLocale] || menu.de;
const { main }: { main: NavigationLink[] } = menuData;
const { navigation_buttons } = config;
const { pathname } = Astro.url;

const cleanPath = (u: string) => u.replace(/\/$/, "");

// Calculate alternative language path
let otherLocaleUrl = Astro.url.pathname;
if (currentLocale === "de") {
  const pathClean = Astro.url.pathname.replace(/\/$/, "");
  otherLocaleUrl = `/en${pathClean || ""}/`;
} else {
  otherLocaleUrl = Astro.url.pathname.replace(/^\/en/, "") || "/";
}
if (!config.site.trailing_slash && otherLocaleUrl !== "/") {
  otherLocaleUrl = otherLocaleUrl.replace(/\/$/, "");
}
---

<div
  class={`header-wrapper ${Astro.url.pathname === "/" || Astro.url.pathname === "/en/" ? "relative" : !errorPage && "pb-6"}`}>
  <header class="header relative">
    <nav class="navbar container relative z-10">
      <!-- logo -->
      <div class="order-0">
        <Logo />
      </div>
      <!-- navbar toggler -->
      <input id="nav-toggle" type="checkbox" class="hidden" />
      <label
        for="nav-toggle"
        class="order-3 flex cursor-pointer items-center text-text-dark lg:order-1 lg:hidden">
        <svg
          id="show-button"
          class="block h-6 fill-current"
          viewBox="0 0 20 20">
          <title>Menu Open</title>
          <path d="M0 3h20v2H0V3z m0 6h20v2H0V9z m0 6h20v2H0V0z"></path>
        </svg>
        <svg
          id="hide-button"
          class="hidden h-6 fill-current"
          viewBox="0 0 20 20">
          <title>Menu Close</title>
          <polygon
            points="11 9 22 9 22 11 11 11 11 22 9 22 9 11 -2 11 -2 9 9 9 9 -2 11 -2"
            transform="rotate(45 10 10)">
          </polygon>
        </svg>
      </label>
      <!-- /navbar toggler -->
      <ul
        id="nav-menu"
        class="navbar-nav order-3 hidden pb-6 lg:order-1 lg:flex lg:w-auto lg:space-x-2 lg:pb-0 xl:space-x-8">
        {
          main.map((menu) => (
            <>
              {menu.hasChildren ? (
                <li class="nav-item nav-dropdown group relative">
                  <span
                    class={`nav-link flex items-center ${
                      menu.children
                        ?.map(({ url }) =>
                          cleanPath(getRelativeLocaleUrl(currentLocale, url)),
                        )
                        .includes(cleanPath(pathname))
                        ? "active"
                        : ""
                    }`}>
                    {menu.name}
                    <span class="arrow-icon">
                      <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                        <path d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z" />
                      </svg>
                    </span>
                  </span>
                  <ul class="nav-dropdown-list max-lg:hidden lg:invisible lg:absolute lg:translate-y-1 lg:opacity-0 lg:transition-all lg:duration-300 lg:group-hover:visible lg:group-hover:block lg:group-hover:translate-y-0 lg:group-hover:opacity-100">
                    {menu.children?.map((child) => (
                      <li class="nav-dropdown-item">
                        <a
                          href={getRelativeLocaleUrl(currentLocale, child.url)}
                          aria-label={child.name}
                          title={child.name}
                          class={`nav-dropdown-link block ${
                            cleanPath(pathname) ===
                              cleanPath(
                                getRelativeLocaleUrl(currentLocale, child.url),
                              ) && "active"
                          }`}>
                          {child.name}
                        </a>
                      </li>
                    ))}
                  </ul>
                </li>
              ) : (
                <li class="nav-item">
                  <a
                    href={getRelativeLocaleUrl(currentLocale, menu.url)}
                    title={menu.name}
                    class={`nav-link flex items-center ${
                      cleanPath(pathname) ===
                        cleanPath(
                          getRelativeLocaleUrl(currentLocale, menu.url),
                        ) && "active"
                    }`}>
                    {menu.name}
                  </a>
                </li>
              )}
            </>
          ))
        }

        {/* Mobile Language Switcher */}
        <li class="nav-item nav-dropdown group relative mt-4 lg:hidden">
          <span
            class="nav-link flex items-center justify-between cursor-pointer">
            <span class="flex items-center gap-2">
              <LanguageFlag
                language={currentLocale as "de" | "en"}
                class="h-4 w-4"
              />
              {currentLocale === "de" ? "Deutsch (DE)" : "English (EN)"}
            </span>
            <span class="arrow-icon">
              <svg class="h-4 w-4 fill-current" viewBox="0 0 20 20">
                <path
                  d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z">
                </path>
              </svg>
            </span>
          </span>
          <ul class="nav-dropdown-list max-lg:hidden">
            <li class="nav-dropdown-item">
              <a
                href={currentLocale === "de" ? "#" : otherLocaleUrl}
                class={`nav-dropdown-link flex items-center gap-2 ${currentLocale === "de" && "active font-bold pointer-events-none"}`}>
                <LanguageFlag
                  language="de"
                  class="h-3.5 w-3.5"
                />
                Deutsch (DE)
              </a>
            </li>
            <li class="nav-dropdown-item">
              <a
                href={currentLocale === "en" ? "#" : otherLocaleUrl}
                class={`nav-dropdown-link flex items-center gap-2 ${currentLocale === "en" && "active font-bold pointer-events-none"}`}>
                <LanguageFlag
                  language="en"
                  class="h-3.5 w-3.5"
                />
                English (EN)
              </a>
            </li>
          </ul>
        </li>

        {
          navigation_buttons.dashboard && (
            <a
              id="mobile-dashboard-btn"
              class="btn btn-primary mt-2 lg:hidden w-full h-[60px] items-center justify-center px-8"
              href={navigation_buttons.dashboard.link}
              title={t('dashboard.label') || navigation_buttons.dashboard.label}
              target={
                navigation_buttons.dashboard.link.startsWith("http")
                  ? "_blank"
                  : "_self"
              }
              style="display: none;"
            >
              {t('dashboard.label') || navigation_buttons.dashboard.label}
            </a>
          )
        }
        {
          navigation_buttons.login && (
            <a
              id="mobile-login-btn"
              class="btn btn-primary mt-2 lg:hidden w-full h-[60px] items-center justify-center px-8"
              href={navigation_buttons.login.link}
              title={t('login.label') || navigation_buttons.login.label}
              target={
                navigation_buttons.login.link.startsWith("http")
                  ? "_blank"
                  : "_self"
              }
            >
              {t('login.label') || navigation_buttons.login.label}
            </a>
          )
        }
      </ul>
      <div class="order-1 ml-auto flex items-center gap-3 md:order-2 lg:ml-0">
        {/* Desktop Language Switcher */}
        <div class="nav-item nav-dropdown group relative hidden lg:block z-50">
          <span
            class="nav-link flex items-center gap-1.5 cursor-pointer text-text hover:text-tertiary px-3 py-2 font-medium transition">
            <LanguageFlag
              language={currentLocale as "de" | "en"}
              class="h-5 w-5"
            />
            {currentLocale.toUpperCase()}
            <span
              class="arrow-icon transition-transform duration-300 group-hover:rotate-180">
              <svg class="h-5 w-5 fill-current" viewBox="0 0 20 20">
                <path
                  d="M9.293 12.95l.707.707L15.657 8l-1.414-1.414L10 10.828 5.757 6.586 4.343 8z">
                </path>
              </svg>
            </span>
          </span>
          <ul
            class="nav-dropdown-list lg:invisible lg:absolute lg:right-0 lg:translate-y-1 lg:opacity-0 lg:transition-all lg:duration-300 lg:group-hover:visible lg:group-hover:block lg:group-hover:translate-y-0 lg:group-hover:opacity-100">
            <li class="nav-dropdown-item">
              <a
                href={currentLocale === "de" ? "#" : otherLocaleUrl}
                class={`nav-dropdown-link flex items-center gap-2 ${currentLocale === "de" && "active font-bold pointer-events-none"}`}>
                <LanguageFlag
                  language="de"
                  class="h-5 w-5"
                />
                Deutsch
              </a>
            </li>
            <li class="nav-dropdown-item">
              <a
                href={currentLocale === "en" ? "#" : otherLocaleUrl}
                class={`nav-dropdown-link flex items-center gap-2 ${currentLocale === "en" && "active font-bold pointer-events-none"}`}>
                <LanguageFlag
                  language="en"
                  class="h-5 w-5"
                />
                English
              </a>
            </li>
          </ul>
        </div>

        {
          navigation_buttons.dashboard && (
            <a
              id="desktop-dashboard-btn"
              class="btn btn-primary hidden lg:flex h-[60px] items-center justify-center px-8"
              href={navigation_buttons.dashboard.link}
              title={t('dashboard.label') || navigation_buttons.dashboard.label}
              target={
                navigation_buttons.dashboard.link.startsWith("http")
                  ? "_blank"
                  : "_self"
              }
              style="display: none;"
            >
              {t('dashboard.label') || navigation_buttons.dashboard.label}
            </a>
          )
        }
        {
          navigation_buttons.login && (
            <a
              id="desktop-login-btn"
              class="btn btn-primary hidden lg:flex h-[60px] items-center justify-center px-8"
              href={navigation_buttons.login.link}
              title={t('login.label') || navigation_buttons.login.label}
              target={
                navigation_buttons.login.link.startsWith("http")
                  ? "_blank"
                  : "_self"
              }
            >
              {t('login.label') || navigation_buttons.login.label}
            </a>
          )
        }
      </div>
    </nav>
  </header>

  {/* Show Only In Home Page */}
  {banner && <HomeBanner content={bannerData} tinaFieldPath={bannerTinaPath} parentData={parentData} />}

  <div aria-hidden="true">
    <ImageMod
      class="pointer-events-none absolute top-0 -z-10 h-full w-full object-cover object-top"
      src={Astro.url.pathname === "/" || Astro.url.pathname === "/en/"
        ? "/images/banner-bg.png"
        : "/images/page-header.png"}
      alt="header image"
      title="header image"
      format="webp"
    />
  </div>

  <script is:inline>
    function updateAuthButtons() {
      try {
        const dataStr = localStorage.getItem("user_data_v2");
        const isLoggedIn = !!dataStr;
        
        const desktopDashboard = document.getElementById("desktop-dashboard-btn");
        const desktopLogin = document.getElementById("desktop-login-btn");
        const mobileDashboard = document.getElementById("mobile-dashboard-btn");
        const mobileLogin = document.getElementById("mobile-login-btn");

        if (isLoggedIn) {
          if (desktopDashboard) desktopDashboard.style.display = "";
          if (desktopLogin) desktopLogin.style.display = "none";
          if (mobileDashboard) mobileDashboard.style.display = "";
          if (mobileLogin) mobileLogin.style.display = "none";
        } else {
          if (desktopDashboard) desktopDashboard.style.display = "none";
          if (desktopLogin) desktopLogin.style.display = "";
          if (mobileDashboard) mobileDashboard.style.display = "none";
          if (mobileLogin) mobileLogin.style.display = "";
        }
      } catch (e) {
        console.error("Error checking auth status:", e);
      }
    }

    // Run immediately for initial render (avoids layout shift)
    updateAuthButtons();

    // Also run on client-side page loads (for Astro ClientRouter)
    document.addEventListener("astro:page-load", updateAuthButtons);
  </script>
</div>
