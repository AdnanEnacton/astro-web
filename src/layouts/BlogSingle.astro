---
import { Image } from "astro:assets";
import dateFormat from "@/lib/utils/dateFormat";
import { humanize, markdownify, plainify } from "@/lib/utils/textConverter";
import { render } from "astro:content";
import ImageMod from "./components/ImageMod.astro";
import BlogSection from "./partials/BlogSection.astro";
import CallToAction from "./partials/CallToAction.astro";

const { post } = Astro.props;
const locale = Astro.currentLocale || "de";

const { body } = post;
const { Content } = await render(post);
const { title, author, image, date } = post.data;

const {
  blog_single_content = { enable: true },
  blog_section = { enable: true, visible_posts: 3 },
  page_cta = { enable: true }
} = post.data;
---

{blog_single_content && blog_single_content.enable !== false && (
  <section class="section pb-0">
    <div class="container">
      <div class="row justify-center">
        <div class="text-center lg:col-9" data-aos="fade-up-sm">
          {title && <h1 set:html={markdownify(title)} class="h2 mb-4" />}
          {body && <p class="mb-6 text-lg">{plainify(body?.slice(0, 190))}</p>}
          <ul class="mb-4 flex items-center justify-center gap-4">
            {author && (
              <li class="text-lg/[inherit]">
                <span class="flex gap-2 font-medium">
                  {humanize(author)}
                </span>
              </li>
            )}
            <li class="flex items-center gap-x-2">
              <Image
                class="h-8 w-8"
                src="/images/icons/png/date.png"
                alt="date icon"
                title="date icon"
                width={25}
                height={25}
              />
              <p class="inline-block font-medium text-tertiary">
                {dateFormat(date, "iiii, MMM dd, yyyy", locale)}
              </p>
            </li>
          </ul>
        </div>
        <div
          class="col-12 pt-20 md:pt-32"
          data-aos="fade-up-sm"
          data-aos-delay="200">
          {
            image && (
              <div class="mb-10">
                <ImageMod
                  src={image}
                  height={500}
                  width={1200}
                  alt={title}
                  title={title}
                  class="h-auto w-full rounded-3xl object-cover md:h-[700px]"
                  format="webp"
                />
              </div>
            )
          }
        </div>
        <article class="pb-10 lg:col-8" data-aos="fade-up-sm">
          <div class="content">
            <Content />
          </div>
        </article>
      </div>
    </div>
  </section>
)}

{blog_section && blog_section.enable !== false && (
  <BlogSection visiblePosts={blog_section.visible_posts || 3} />
)}

{page_cta && page_cta.enable !== false && (
  <CallToAction content={page_cta} />
)}
