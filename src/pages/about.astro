---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import AboutBanner from "@/partials/AboutBanner.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Clients from "@/partials/Clients.astro";
import Faq from "@/partials/Faq.astro";
import OurTeam from "@/partials/OurTeam.astro";
import OurValues from "@/partials/OurValues.astro";

const locale = Astro.currentLocale || "de";
const aboutIndex = await getListPage("about", `${locale}/about`);
if (aboutIndex.data.draft) {
  return Astro.redirect(locale === "en" ? "/en/404" : "/404");
}
const { about_banner, clients, our_values, our_team, faq, page_cta } = aboutIndex.data;
---

<Base {...aboutIndex.data}>
  {about_banner && about_banner.enable !== false && <AboutBanner content={about_banner} />}
  {clients && clients.enable !== false && <Clients content={clients} />}
  {our_values && our_values.enable !== false && <OurValues content={our_values} />}
  {our_team && our_team.enable !== false && <OurTeam content={our_team} />}
  {faq && faq.enable !== false && <Faq />}
  {page_cta && page_cta.enable !== false && <CallToAction content={page_cta} />}
</Base>
