---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import Clients from "@/partials/Clients.astro";
import Faq from "@/partials/Faq.astro";
import PricingSection from "@/partials/PricingSection.astro";
import Testimonial from "@/partials/Testimonial.astro";

const locale = Astro.currentLocale || "de";
const pricing = await getListPage(
  "pricing",
  `${locale}/pricing`
);
if(pricing.data.draft){
  return Astro.redirect(locale === "en" ? "/en/404" : "/404");
}
const { pricing: pricing_section, clients, testimonial, faq, page_cta } = pricing.data;
---

<Base {...pricing.data}>
  {pricing_section && pricing_section.enable !== false && <PricingSection largeHeading={true} content={pricing_section} />}
  {clients && clients.enable !== false && <Clients content={clients} />}
  {testimonial && testimonial.enable !== false && <Testimonial content={testimonial} visible_testimonial={3} />}
  {faq && faq.enable !== false && <Faq />}
  {page_cta && page_cta.enable !== false && <CallToAction content={page_cta} />}
</Base>
