---
import Base from "@/layouts/Base.astro";
import { getSinglePage } from "@/lib/contentParser.astro";
import PageHeader from "@/partials/PageHeader.astro";
import PageSections from "@/partials/PageSections.astro";
import CallToAction from "@/partials/CallToAction.astro";
import config from "@/config/config.json";
import { useTranslations } from "@/i18n/ui";
import { render } from "astro:content";
import dayjs from "dayjs";
import TinaIsland from "@tinacms/astro/TinaIsland.astro";

export async function getStaticPaths() {
  const homepage = await getSinglePage("homepage");
  const about = await getSinglePage("about");
  const contact = await getSinglePage("contact");
  const pricing = await getSinglePage("pricing");
  const features = await getSinglePage("features");
  const pages = await getSinglePage("pages");
  const blogPage = await getSinglePage("blogPage");

  const collections = [
    { type: "homepage", entries: homepage },
    { type: "about", entries: about },
    { type: "contact", entries: contact },
    { type: "pricing", entries: pricing },
    { type: "features", entries: features },
    { type: "pages", entries: pages },
    { type: "blogPage", entries: blogPage },
  ];

  const paths = collections.flatMap(({ type, entries }) => {
    return entries.map((entry) => {
      const [locale, ...nameParts] = entry.id.split("/");
      const name = nameParts.join("/");

      let slug: string | undefined;
      if (locale === "de") {
        slug = name === "home" ? undefined : name;
      } else {
        slug = name === "home" ? locale : `${locale}/${name}`;
      }

      return {
        params: { slug },
        props: { page: entry, type, locale },
      };
    });
  });

  return paths;
}

const { page, type, locale } = Astro.props;
const data = page.data as any;

// Page rendering helpers for regular markdown pages
let Content = null;
let lastModified = "";

if (type === "pages") {
  const rendered = await render(page);
  Content = rendered.Content;
  lastModified = dayjs(rendered.remarkPluginFrontmatter.lastModified).format(
    "MMMM DD, YYYY"
  );
}

// Blog posts loading (only if blog_section or pagination is configured)
let posts: any[] = [];
let totalPages = 0;
const hasBlogSection = data.blog_section || data.pagination || 
  (data.sections && data.sections.some((s: any) => s._template === "blog_section" || s._template === "pagination"));

if (hasBlogSection) {
  posts = (await getSinglePage("blog")).filter((post) =>
    post.id.startsWith(locale + "/")
  );
  totalPages = Math.ceil(posts.length / config.settings.pagination);
}

// Homepage-specific variables
let bannerSection = null;
let homeSchema = undefined;

if (data.sections) {
  bannerSection = data.sections.find((s: any) => s._template === "banner");
}

if (!bannerSection && type === "homepage") {
  bannerSection = data.banner;
}

if (type === "homepage") {
  const t = useTranslations(locale as any);
  homeSchema = [
    {
      "@context": "https://schema.org",
      "@type": "WebSite",
      "name": config.site.title,
      "url": config.site.base_url
    },
    {
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": config.site.title,
      "url": config.site.base_url,
      "logo": `${config.site.base_url}${config.site.logo}`,
      "description": t("footer.description")
    }
  ];
}
---

<Base
  title={data.title}
  meta_title={data.meta_title}
  description={data.description}
  image={data.image}
  keywords={data.keywords}
  banner={bannerSection ? bannerSection.enable !== false : undefined}
  bannerData={bannerSection}
  schema={type === "homepage" ? homeSchema : undefined}
>
  {/* Render standard generic markdown page */}
  {type === "pages" ? (
    <>
      <PageHeader title={data.title} lastModified={lastModified} />
      <section class="section">
        <div class="container" data-aos="fade-up-sm" data-aos-delay={200}>
          <div class="row justify-center">
            <div class="lg:col-10">
              <div class="content">
                {Content && <Content />}
              </div>
            </div>
          </div>
        </div>
      </section>
      <CallToAction />
    </>
  ) : (
    /* Render modular section list */
    <TinaIsland
      name="page-layout"
      wrapper={{ tag: "main" }}
      params={{ slug: page.id, locale, type }}
      primary={true}
    >
      <PageSections data={data} posts={posts} totalPages={totalPages} type={type} />
    </TinaIsland>
  )}

</Base>
