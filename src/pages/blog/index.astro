---
import Pagination from "@/components/Pagination.astro";
import config from "@/config/config.json";
import Base from "@/layouts/Base.astro";
import { getListPage, getSinglePage } from "@/lib/contentParser.astro";
import BlogSection from "@/partials/BlogSection.astro";
import CallToAction from "@/partials/CallToAction.astro";

const BLOG_FOLDER = "blog";
const locale = Astro.currentLocale || "de";

const postIndex = await getListPage(
  "blogPage",
  `${locale}/blog`
);
if (postIndex.data.draft) {
  return Astro.redirect(locale === "en" ? "/en/404" : "/404");
}
const posts = (await getSinglePage(BLOG_FOLDER)).filter(post => post.id.startsWith(locale + "/"));
const totalPages: number = Math.ceil(posts.length / config.settings.pagination);
const { blog_section, pagination, page_cta } = postIndex.data;
---

<Base {...postIndex.data}>
  {blog_section && blog_section.enable !== false && (
    <BlogSection
      largeHeading={blog_section.large_heading}
      content={blog_section}
      visiblePosts={blog_section.visible_posts}
      cardLayout={blog_section.card_layout}
      posts={posts}
    />
  )}
  <BlogSection visiblePosts={3} posts={posts} />
  {pagination && pagination.enable !== false && <Pagination section={BLOG_FOLDER} totalPages={totalPages} />}
  {page_cta && page_cta.enable !== false && <CallToAction content={page_cta} />}
</Base>
