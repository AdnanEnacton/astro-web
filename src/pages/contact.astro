---
import Base from "@/layouts/Base.astro";
import { getListPage } from "@/lib/contentParser.astro";
import CallToAction from "@/partials/CallToAction.astro";
import ContactHero from "@/partials/ContactHero.astro";
import Faq from "@/partials/Faq.astro";

const locale = Astro.currentLocale || "de";
const contactIndex = await getListPage(
  "contact",
  `${locale}/contact`
);

if (contactIndex.data.draft){
  return Astro.redirect(locale === "en" ? "/en/404" : "/404");
}
const { contact_hero, faq, page_cta } = contactIndex.data;
---

<Base {...contactIndex.data}>
  {contact_hero && contact_hero.enable !== false && <ContactHero content={contact_hero} />}
  {faq && faq.enable !== false && <Faq />}
  {page_cta && page_cta.enable !== false && <CallToAction content={page_cta} />}
</Base>
